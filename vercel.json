{
  "functions": {
    "api/index.js": {
      "includeFiles": "data/**,images/**,videos/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!images|videos|index.html|setup.html).*)",
      "destination": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/videos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
