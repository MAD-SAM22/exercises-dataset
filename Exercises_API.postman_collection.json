  "item": [
    {
      "name": "Exercises",
      "item": [
        {
          "name": "Get Paginated Exercises",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/exercises?page=1&limit=20&body_part=waist&equipment=body weight&target=abs&q=sit-up",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "exercises"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Items per page (default: 20, max: 100)"
                },
                {
                  "key": "body_part",
                  "value": "waist",
                  "description": "Filter by body part ('back', 'cardio', 'chest', 'lower arms', 'lower legs', 'neck', 'shoulders', 'upper arms', 'upper legs', 'waist')"
                },
                {
                  "key": "equipment",
                  "value": "body weight",
                  "description": "Filter by equipment ('body weight', 'dumbbell', 'barbell', etc.)"
                },
                {
                  "key": "target",
                  "value": "abs",
                  "description": "Filter by primary target muscle"
                },
                {
                  "key": "q",
                  "value": "sit-up",
                  "description": "Search keyword for exercise name or muscles"
                }
              ]
            },
            "description": "Retrieves a paginated list of exercise records with support for search and filtering."
          }
        },
        {
          "name": "Get Exercises with Multi-Select & Sorting & Fields",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/exercises?body_part=chest,waist&sort=name_asc&fields=id,name,category,target,equipment,image,gif_url&limit=10",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "exercises"
              ],
              "query": [
                {
                  "key": "body_part",
                  "value": "chest,waist",
                  "description": "Comma-separated body parts"
                },
                {
                  "key": "sort",
                  "value": "name_asc",
                  "description": "Sort order ('name_asc', 'name_desc', 'id_asc', 'id_desc')"
                },
                {
                  "key": "fields",
                  "value": "id,name,category,target,equipment,image,gif_url",
                  "description": "Comma-separated list of fields to include in response"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Retrieve exercises with multi-value filtering, custom sorting, and partial field selection."
          }
        },
        {
          "name": "Get Single Exercise by ID",
