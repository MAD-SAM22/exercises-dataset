              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "exercises",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "0001",
                  "description": "Zero-padded 4-digit or numeric exercise ID"
                }
              ]
            },
            "description": "Fetch a single exercise object by its unique ID."
          }
        },
